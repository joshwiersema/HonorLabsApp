# WooCommerce Store Credentials
WC_SITE_URL=https://yourstore.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxx

# JWT Auth
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY_HOURS=72

# Users — format: username:password,username:password
APP_USERS=josh:changeme,user2:changeme

# CORS (comma-separated or JSON array for production)
CORS_ORIGINS=["http://localhost:5173"]

# Debug
DEBUG=true
